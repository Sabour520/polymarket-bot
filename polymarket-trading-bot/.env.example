# ── Polymarket CLOB API ──────────────────────────────────────────────────────
# Your EOA private key — NEVER commit your real key, use a dedicated trading wallet
POLYMARKET_PRIVATE_KEY=0

# Your wallet address (used as the funder/signer for EIP-1271 orders)
POLYMARKET_FUNDER_ADDRESS=0x859bc4a87De163A961e5970bB35ccae33E39181f

# Optional overrides (defaults shown)
# POLYMARKET_HOST=https://clob.polymarket.com
# POLYMARKET_CHAIN_ID=137
# Note: API credentials are derived automatically from your private key —
#       no manual API key/secret/passphrase configuration needed.

# ── Bot settings ─────────────────────────────────────────────────────────────
# Starting capital in USD (informational — bot reads wallet balance via API)
BOT_CAPITAL_USD=500.0
BOT_MAX_POSITION_USD=100.0
BOT_ORDER_SIZE_USD=10.0
BOT_ORDER_TTL_SECONDS=300
BOT_MIN_CONFIDENCE=0.1
BOT_POLL_INTERVAL_SECONDS=60

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
